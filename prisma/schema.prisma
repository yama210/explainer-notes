generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum NoteType {
  concept
  error
  phrase
  procedure
}

enum Subject {
  programming
  english
  other
}

model Note {
  id        String    @id @default(cuid())
  title     String
  content   String
  noteType  NoteType
  subject   Subject
  noteTags  NoteTag[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  noteTags  NoteTag[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model NoteTag {
  noteId    String
  tagId     String
  note      Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@id([noteId, tagId])
  @@index([tagId])
}
